# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional fallback if your Supabase dashboard labels the browser key as anon/public.
# Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY when available.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local development only. Do not set this in production.
PREVE_DEV_BYPASS_AUTH=false

# Server-only. Supabase project settings > API > service_role key.
# Required for account deletion. Never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Reddit app credentials (reddit.com/prefs/apps -> create app -> "web app").
# Redirect URI must be: https://<your-domain>/api/connect/reddit/callback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

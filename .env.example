# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional fallback if your Supabase dashboard labels the browser key as anon/public.
# Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY when available.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local development only. Do not set this in production.
PREVE_DEV_BYPASS_AUTH=false

# Server-only. Supabase project settings > API > service_role key.
# Required for account deletion. Never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Reddit app credentials (reddit.com/prefs/apps -> create app -> "web app").
# Redirect URI must be: https://<your-domain>/api/connect/reddit/callback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional but recommended: encrypts OAuth tokens at rest (AES-256-GCM).
# Any long random string (32+ chars), e.g. output of: openssl rand -base64 32
# Set it BEFORE users connect accounts; changing it later invalidates stored
# tokens (users just reconnect). Server-only.
TOKEN_ENCRYPTION_KEY=

# AI actions (summarize / rewrite / repurpose). Server-only.
# Default provider is Groq (free): create a key at console.groq.com.
# AI_BASE_URL / AI_MODEL are optional overrides for any OpenAI-compatible API.
AI_API_KEY=
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

# Fallback provider: used automatically when Groq is rate-limited/unavailable.
# Free key at aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# "Support preve" — a HOSTED payment page URL (Paystack/Flutterwave payment
# page, Stripe Payment Link, Ko-fi, ...). preve never handles cards; it only
# opens this link. Leave empty to hide all Support buttons (landing footer,
# Settings, account menu). Must be https.
NEXT_PUBLIC_DONATE_URL=
